<Page x:Class="TaskForge.Views.Pages.AchievementsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="Достижения">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Достижения" 
                   Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                   Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1">
            <WrapPanel>
                <ItemsControl ItemsSource="{Binding Achievements}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <materialDesign:Card Margin="8" 
                                                  Width="200" 
                                                  Padding="12"
                                                  UniformCornerRadius="8">
                                <StackPanel>
                                    <materialDesign:PackIcon Kind="{Binding Icon}" 
                                                             Width="48" Height="48"
                                                             Margin="0,0,0,8"
                                                             HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}" 
                                               Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                               TextAlignment="Center"/>
                                    <TextBlock Text="{Binding Description}" 
                                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center"/>
                                    <TextBlock Text="Не получено" 
                                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                               Foreground="Gray"
                                               HorizontalAlignment="Center"
                                               Margin="0,8,0,0"
                                               Visibility="{Binding IsUnlocked, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </StackPanel>
                            </materialDesign:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </WrapPanel>
        </ScrollViewer>
    </Grid>
</Page>
