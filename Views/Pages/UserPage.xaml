<Page x:Class="TaskForge.Views.Pages.UserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="Профиль пользователя">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Карточка пользователя -->
            <materialDesign:Card Grid.Row="0" 
                                 UniformCornerRadius="12" 
                                 Padding="16" 
                                 Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Аватар (иконка) -->
                    <materialDesign:PackIcon Grid.Column="0" 
                                             Kind="AccountCircle" 
                                             Width="64" Height="64"
                                             VerticalAlignment="Center"/>

                    <!-- Информация -->
                    <StackPanel Grid.Column="1" Margin="16,0">
                        <TextBlock Text="{Binding CurrentUserName}" 
                                   Style="{StaticResource MaterialDesignHeadline6TextBlock}"/>
                        <TextBlock Text="{Binding CurrentUserEmail}" 
                                   Style="{StaticResource MaterialDesignBody2TextBlock}"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <materialDesign:Chip Margin="0,0,8,0">
                                <TextBlock>
                                    <Run Text="Уровень: "/>
                                    <Run Text="{Binding CurrentUserLevel, Mode=OneWay}"/>
                                </TextBlock>
                                    </materialDesign:Chip>
                                    <materialDesign:Chip>
                                <TextBlock>
                                    <Run Text="Опыт: "/>
                                    <Run Text="{Binding CurrentUserExp, Mode=OneWay}"/>
                                    <Run Text=" XP"/>
                                </TextBlock>
                            </materialDesign:Chip>
                        </StackPanel>
                    </StackPanel>

                    <!-- Кнопка редактирования -->
                    <Button Grid.Column="2" 
                            Style="{StaticResource MaterialDesignIconButton}"
                            ToolTip="Редактировать профиль"
                            Click="EditProfile_Click">
                        <materialDesign:PackIcon Kind="Edit"/>
                    </Button>
                </Grid>
            </materialDesign:Card>

            <!-- Выполненные задачи -->
            <Expander Grid.Row="1" 
                      Header="Выполненные задачи" 
                      IsExpanded="True"
                      Margin="0,0,0,16"
                      Style="{StaticResource MaterialDesignExpander}">
                <Frame x:Name="CompletedTasksFrame" 
                       NavigationUIVisibility="Hidden"
                       Height="300"/>
            </Expander>

            
        </Grid>
    </ScrollViewer>
</Page>