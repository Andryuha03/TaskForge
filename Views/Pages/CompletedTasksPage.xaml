<Page x:Class="TaskForge.Views.Pages.CompletedTasksPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="Выполненные задачи">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="0*"/>
        </Grid.RowDefinitions>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.RowSpan="2">
            <ItemsControl ItemsSource="{Binding CompletedTasks}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <materialDesign:Card Margin="0,0,0,8" Padding="12" UniformCornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Name}" 
                                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}"/>
                                    <TextBlock Text="{Binding Info}" 
                                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                                               TextWrapping="Wrap"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="Приоритет: "/>
                                        <TextBlock Text="{Binding Priority}" Margin="0,0,8,0"/>
                                        <TextBlock Text="Опыт: "/>
                                        <TextBlock Text="{Binding Reward_exp}" Margin="0,0,8,0"/>
                                        <TextBlock Text="XP" Margin="0,0,8,0"/>
                                        <TextBlock Text="Время: "/>
                                        <TextBlock Text="{Binding ActualTimeDisplay}"/>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Grid.Column="1" 
                                           Text="{Binding Update_at, StringFormat='dd.MM.yyyy'}"
                                           VerticalAlignment="Center"
                                           Margin="12,0,0,0"/>
                            </Grid>
                        </materialDesign:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>