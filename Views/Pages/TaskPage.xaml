<Page x:Class="TaskForge.Views.Pages.TaskPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="Задачи">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="Мои задачи" 
                       Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                       VerticalAlignment="Center"/>
            <Button Content="+ Новая задача"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Command="{Binding AddTaskCommand}"
                    Margin="16,0,0,0"
                    HorizontalAlignment="Right"/>
        </StackPanel>

        <!-- Список задач, занимает всё оставшееся пространство -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Tasks}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <materialDesign:Card Margin="0,0,0,8" Padding="12" UniformCornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <!-- занимает всё свободное место -->
                                    <ColumnDefinition Width="Auto"/>
                                    <!-- кнопки и время -->
                                </Grid.ColumnDefinitions>

                                <!-- Левая часть: информация о задаче -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Name}" 
                                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Info}" 
                                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                                               TextWrapping="Wrap"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <materialDesign:Chip Content="{Binding Priority}" Margin="0,0,8,0"/>
                                        <materialDesign:Chip Content="{Binding Status}"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Правая часть: время и кнопки -->
                                <StackPanel Grid.Column="1" 
                                            Orientation="Horizontal" 
                                            VerticalAlignment="Center"
                                            Margin="12,0,0,0">
                                    <TextBlock Text="{Binding ActualTimeDisplay}" 
                                               VerticalAlignment="Center" 
                                               Margin="0,0,8,0"
                                               Style="{StaticResource MaterialDesignBody2TextBlock}"/>
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            ToolTip="Таймер"
                                            Command="{Binding DataContext.ToggleTimerCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="Timer" />
                                    </Button>
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            ToolTip="Редактировать"
                                            Command="{Binding DataContext.EditTaskCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="Edit" />
                                    </Button>
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            ToolTip="Выполнить"
                                            Command="{Binding DataContext.CompleteTaskCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="Check" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </materialDesign:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>