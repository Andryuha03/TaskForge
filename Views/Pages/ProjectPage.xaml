<Page x:Class="TaskForge.Views.Pages.ProjectPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="Проекты">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок и кнопка добавления проекта -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Stretch">
            <TextBlock Text="Мои проекты" 
                       Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                       VerticalAlignment="Center"/>
            <Button Content="+ Проект" 
                    Command="{Binding AddProjectCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    HorizontalAlignment="Right"
                    Margin="16,0,0,0"/>
        </StackPanel>

        <!-- Список проектов -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,16,0,0">
            <ItemsControl ItemsSource="{Binding Projects}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <materialDesign:Card Margin="0,0,0,16" Padding="0" UniformCornerRadius="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="4"/>
                                </Grid.RowDefinitions>
                                <!-- Верхняя часть: заголовок проекта и кнопка удаления -->
                                <Grid Grid.Row="0" Margin="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Expander Grid.Column="0" 
                                              Header="{Binding Name}" 
                                              IsExpanded="{Binding IsExpanded, Mode=TwoWay}"
                                              Style="{StaticResource MaterialDesignExpander}">
                                        <Expander.Content>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Info}" 
                                                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                           TextWrapping="Wrap" Margin="0,4,0,8"/>
                                                <ItemsControl ItemsSource="{Binding Tasks}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="{Binding Project.ColorLightBrush}" 
                                                                    CornerRadius="6" Margin="0,0,0,8" Padding="8">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <StackPanel Grid.Column="0">
                                                                        <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                                                        <TextBlock Text="{Binding Info}" 
                                                                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                                                   TextWrapping="Wrap"/>
                                                                        <StackPanel Orientation="Horizontal" Margin="0,4">
                                                                            <materialDesign:Chip Content="{Binding Status}" />
                                                                        </StackPanel>
                                                                    </StackPanel>
                                                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                                                                ToolTip="Выполнить" 
                                                                                Command="{Binding DataContext.CompleteTaskCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                                CommandParameter="{Binding}">
                                                                            <materialDesign:PackIcon Kind="Check" />
                                                                        </Button>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <Button Content="+ Новая задача" 
                                                        Command="{Binding DataContext.AddTaskCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource MaterialDesignFlatButton}"
                                                        Margin="0,8,0,0"/>
                                            </StackPanel>
                                        </Expander.Content>
                                    </Expander>
                                    <Button Grid.Column="1" 
                                            Style="{StaticResource MaterialDesignIconButton}"
                                            ToolTip="Удалить проект"
                                            Command="{Binding DataContext.DeleteProjectCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="Delete" />
                                    </Button>
                                </Grid>
                                <!-- Цветная полоса внизу -->
                                <Border Grid.Row="1" Background="{Binding ColorBrush}" Height="4" CornerRadius="0,0,8,8"/>
                            </Grid>
                        </materialDesign:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>