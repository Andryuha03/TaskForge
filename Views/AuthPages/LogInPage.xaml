<Page x:Class="TaskForge.Views.AuthPages.LogInPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TaskForge.Views.AuthPages"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="450"
      Title="LogInPage">

    <Grid>
        <Border CornerRadius="20" Background="White" VerticalAlignment="Center" Padding="30" Margin="30">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" Color="Black" ShadowDepth="0"/>
            </Border.Effect>
            <StackPanel>
                <TextBox x:Name="textBoxLogIn" materialDesign:HintAssist.Hint="Имя" Margin="5" Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>
                <PasswordBox x:Name="passBox" materialDesign:HintAssist.Hint="Пароль" Margin="5" Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"/>
                <Button x:Name="LoginBtn" Content="Войти" Margin="0 10 0 10"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
