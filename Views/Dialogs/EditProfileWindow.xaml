<Window x:Class="TaskForge.Views.Dialogs.EditProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Редактировать профиль" Width="400" Height="350"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="16">
        <TextBox x:Name="NameBox" materialDesign:HintAssist.Hint="Имя" Text="{Binding Name}" Margin="0,8"/>
        <TextBox x:Name="EmailBox" materialDesign:HintAssist.Hint="Email" Text="{Binding Email}" Margin="0,8"/>
        <PasswordBox x:Name="PasswordBox" materialDesign:HintAssist.Hint="Новый пароль (оставьте пустым, если не менять)" Margin="0,8"/>
        <PasswordBox x:Name="ConfirmBox" materialDesign:HintAssist.Hint="Подтверждение пароля" Margin="0,8"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
            <Button Content="Отмена" Command="{Binding CancelCommand}" Style="{StaticResource MaterialDesignFlatButton}"/>
            <Button Content="Сохранить" Command="{Binding SaveCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Margin="8,0,0,0"/>
        </StackPanel>
    </StackPanel>
</Window>
