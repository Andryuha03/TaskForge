<Window x:Class="TaskForge.Views.Dialogs.ProjectEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:converters="clr-namespace:TaskForge.Converters"
        Title="Редактирование проекта" Width="500" Height="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Style="{StaticResource MaterialDesignWindow}">
    <Window.Resources>
        <converters:BoolToNewEditTextConverter x:Key="BoolToNewEditTextConverter"/>
    </Window.Resources>
    <StackPanel Margin="16">
        <TextBlock Text="{Binding IsNew, Converter={StaticResource BoolToNewEditTextConverter}, ConverterParameter=Проект}" 
                   FontSize="20" Margin="0,0,0,16"/>

        <TextBox materialDesign:HintAssist.Hint="Название" 
                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBox materialDesign:HintAssist.Hint="Описание" 
                 Text="{Binding Info}" 
                 MinHeight="80" TextWrapping="Wrap" Margin="0,8,0,0"/>

        <DatePicker SelectedDate="{Binding Deadline}" 
                    materialDesign:HintAssist.Hint="Дедлайн" 
                    Margin="0,8,0,0"/>

        <materialDesign:ColorPicker Color="{Binding SelectedColor, Mode=TwoWay}"
                                    materialDesign:HintAssist.Hint="Цвет метки"
                                    Margin="0,8,0,0"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Отмена" Command="{Binding CancelCommand}" 
                    Style="{StaticResource MaterialDesignFlatButton}"/>
            <Button Content="Сохранить" Command="{Binding SaveCommand}" 
                    Style="{StaticResource MaterialDesignRaisedButton}" Margin="8,0,0,0"/>
        </StackPanel>
    </StackPanel>
</Window>